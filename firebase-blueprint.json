{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Private profile information for patients.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier from Firebase Auth" },
        "displayName": { "type": "string", "description": "Patient's full name" },
        "email": { "type": "string", "format": "email", "description": "Patient's email address" },
        "phone": { "type": "string", "description": "Patient's contact number for SMS/WhatsApp" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["patient", "admin"] }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Details about a booked consultation.",
      "type": "object",
      "properties": {
        "patientName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "doctor": { "type": "string" },
        "date": { "type": "string", "description": "Formated date string" },
        "slot": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientName", "email", "doctor", "date", "slot", "status"]
    },
    "Payment": {
      "title": "Payment Record",
      "description": "Records of UPI and QR transactions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "appointmentId": { "type": "string" },
        "patientUid": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["upi", "qr"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["appointmentId", "patientUid", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Private user profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment bookings."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment transactions."
    }
  }
}
