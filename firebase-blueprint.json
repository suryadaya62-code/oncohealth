{
  "entities": {
    "User": {
      "title": "User",
      "description": "Patient or Doctor profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled oncology consultation.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string", "description": "UID of the patient." },
        "patientName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "doctor": { "type": "string" },
        "date": { "type": "string" },
        "slot": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] }
      },
      "required": ["patientName", "email", "phone", "doctor", "date", "slot", "createdAt", "status"]
    },
    "Prescription": {
      "title": "Prescription",
      "description": "Medication prescribed by a doctor.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the patient." },
        "doctorName": { "type": "string" },
        "medication": { "type": "string" },
        "dosage": { "type": "string" },
        "frequency": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "doctorName", "medication", "dosage", "frequency", "createdAt"]
    },
    "MedicalRecord": {
      "title": "Medical Record",
      "description": "Patient medical history, test results, etc.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["lab-result", "diagnosis", "imaging", "surgery"] },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "type", "date", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Secure message between patient and doctor.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["senderId", "receiverId", "participants", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Patient appointments."
    },
    "/prescriptions/{prescriptionId}": {
      "schema": "Prescription",
      "description": "Patient prescriptions."
    },
    "/medicalRecords/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Patient medical history."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Secure messages."
    }
  }
}
